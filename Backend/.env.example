PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/ai-job-automation
JWT_SECRET=replace-with-a-long-random-secret
REDIS_URL=redis://127.0.0.1:6379

# SMTP Email Configuration (Required for actual email sending to HR, otherwise simulated in logs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="AI Job Application Automator <your-email@gmail.com>"
SMTP_SECURE=false
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini
HEADLESS=true
PLAYWRIGHT_HEADLESS=true
AUTOMATION_DEBUG=false
BROWSER_TIMEOUT=60000
AUTOMATION_WORKERS=2
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_DELAY_MS=30000
WORKER_QUEUE_RATE_MAX=10
WORKER_QUEUE_RATE_DURATION_MS=60000
PLATFORM_RATE_LIMIT_MAX=5
PLATFORM_RATE_LIMIT_WINDOW_SECONDS=60
AUTOMATION_TIMEZONE=Asia/Kolkata
AUTOMATION_LOCALE=en-US
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=300
COPILOT_BROWSER_CHANNEL=chrome
CANDIDATE_NOTICE_PERIOD=Immediate
CANDIDATE_CURRENT_CTC=
CANDIDATE_EXPECTED_CTC=
CANDIDATE_FIRST_NAME=
CANDIDATE_MIDDLE_NAME=
CANDIDATE_LAST_NAME=
CANDIDATE_PHONE=
CANDIDATE_EMAIL=
CANDIDATE_GENDER=
CANDIDATE_DOB=
CANDIDATE_EXPERIENCE_YEARS=
CANDIDATE_EXPERIENCE_MONTHS=
CANDIDATE_AVAILABLE_TO_JOIN_DAYS=
CANDIDATE_PREFERRED_LOCATION=
CANDIDATE_CURRENT_LOCATION=
CANDIDATE_SKILLS=
CANDIDATE_WORK_AUTHORIZED=Yes
CANDIDATE_COMMUTE_RELOCATE=Yes, I am able to commute
CANDIDATE_OFFICE_ARRANGEMENT_OK=Yes
CANDIDATE_SHIFT_AVAILABILITY=Yes
CANDIDATE_PREVIOUSLY_APPLIED=No
CANDIDATE_RELATIVES_EMPLOYED=No
CANDIDATE_CONFLICT_OF_INTEREST=No
CANDIDATE_CRIMINAL_CONVICTION=No

ALLOW_GLOBAL_JOBS=false

# Production security
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-me
DISABLE_BULL_BOARD=false
AUTH_RATE_LIMIT_MAX=20
INGESTION_LOCK_TTL_SECONDS=900
INGESTION_FETCH_TIMEOUT_MS=90000
STARTUP_INGESTION_DELAY_MS=3000
DISABLE_STARTUP_INGESTION=false

# Automation safety (use dry-run until verified)
AUTOMATION_MODE=dry-run
